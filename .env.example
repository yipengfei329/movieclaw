APP_NAME=movieclaw
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# ─────────────────────────────────────────────────────────────
# 运行日志落盘（设置页「系统日志」可在线查看）
#
# 后端全部运行日志按天写入 LOG_DIR 下的 movieclaw-YYYY-MM-DD.log。
# 默认与数据库同在 data/ 目录，Docker 部署挂载 data/ 卷即可保证
# 容器重启 / 升级镜像日志不丢。超过保留天数的旧日志自动删除。
# ─────────────────────────────────────────────────────────────
# LOG_DIR=./data/logs
# LOG_RETENTION_DAYS=30

# ─────────────────────────────────────────────────────────────
# TMDB 影视元数据（发现电影 / 发现剧集页面的数据源）
#
# 未配置时「发现」页自动禁用，其余功能不受影响。
# 在 themoviedb.org 免费注册后到「账户设置 → API」页申请，
# 两种密钥都支持、自动识别：
#   - API Read Access Token（"eyJ" 开头的长令牌）
#   - API Key（32 位十六进制）
# 所在网络无法直连 TMDB 时，可将下面两个地址改为镜像/自建反代。
# ─────────────────────────────────────────────────────────────
# TMDB_API_KEY=
# TMDB_API_BASE_URL=https://api.themoviedb.org/3
# TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p
# TMDB_LANGUAGE=zh-CN
# TMDB_REGION=CN

# ─────────────────────────────────────────────────────────────
# 远程图片磁盘缓存
#
# 页面上所有远程图片（TMDB 海报、豆瓣剧照、PT 站种子详情图等）都经
# 后端统一代理并缓存到本地磁盘，二次访问不再回源互联网。
# 目录默认与数据库同在 data/ 下，Docker 部署挂载 data 一个卷即可。
# ─────────────────────────────────────────────────────────────
# IMAGE_CACHE_DIR=./data/cache/images
# 容量上限（MB），超限自动按「最久未访问」清理
# IMAGE_CACHE_MAX_MB=2048

# ─────────────────────────────────────────────────────────────
# 订阅模拟投递（调试用）
#
# 设为 true 后订阅命中资源时只写日志与活动时间线，不真正取种、
# 不提交下载器（状态机照常推进，时间线标注"模拟投递"）。
# 适合调试匹配规则或初次部署时先观察订阅行为。默认 false（真实投递）。
# ─────────────────────────────────────────────────────────────
# SUBSCRIPTION_DISPATCH_DRY_RUN=false

# ─────────────────────────────────────────────────────────────
# 集成测试用的真实站点 Cookie（仅本地填写，不要提交）
#
# 复制本文件为 .env 后再编辑：cp .env.example .env
# .env 已在 .gitignore 中，不会进入 git 历史。
#
# 留空时对应站点的集成测试会自动跳过，不影响 CI。
# 获取方式：浏览器 DevTools → Network → 任意请求 →
#   Request Headers → 复制 Cookie 整行的值
# ─────────────────────────────────────────────────────────────
MOVIECLAW_TEST_COOKIES_SSD=
MOVIECLAW_TEST_COOKIES_TTG=
MOVIECLAW_TEST_COOKIES_CHDBITS=
