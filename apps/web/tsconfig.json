{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next-breadcrumb/types/**/*.ts",
    ".next-extinstall/types/**/*.ts",
    ".next-importbadge/types/**/*.ts",
    ".next-newtask/types/**/*.ts",
    ".next-preview-dirpick/types/**/*.ts",
    ".next-preview-libhome/types/**/*.ts",
    ".next-preview-library/types/**/*.ts",
    ".next-subcancel/types/**/*.ts",
    ".next-subinspector/types/**/*.ts",
    ".next-wishbtn/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts",
    ".next-preview-pathmap/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
